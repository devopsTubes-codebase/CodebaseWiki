INTERNAL_POSTGRES_ENABLED=true
INTERNAL_POSTGRES_HOST=codebase-wiki-postgres
INTERNAL_POSTGRES_PORT=5432
INTERNAL_POSTGRES_DB=codebase_wiki
INTERNAL_POSTGRES_USER=codebase_wiki
INTERNAL_POSTGRES_PASSWORD=REPLACE_WITH_INTERNAL_POSTGRES_PASSWORD
DATABASE_URL=postgres://codebase_wiki:REPLACE_WITH_INTERNAL_POSTGRES_PASSWORD@codebase-wiki-postgres:5432/codebase_wiki
DATABASE_SSL_ENABLED=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_SSL_ROOT_CERT=
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4-turbo-preview
AI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=text-embedding-004
ENCRYPTION_SECRET_KEY=REPLACE_WITH_32_PLUS_CHAR_SECRET
NEXTAUTH_URL=https://wiki-team.hackathon.sev-2.com
NEXTAUTH_SECRET=REPLACE_WITH_NEXTAUTH_SECRET
TEMP_STORAGE_PATH=/tmp/codebase-wiki
DOCS_STORAGE_PATH=/tmp/codebase-wiki-docs
VECTOR_INDEX_PATH=/tmp/codebase-wiki-index
